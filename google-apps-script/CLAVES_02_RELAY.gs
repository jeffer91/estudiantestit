function clavesGuardarIA_(d){d=d||{};var id=clavesId_(d.id||d.proveedor||d.providerId||d.nombre);if(!id)throw new Error('Falta ID del proveedor.');var f=clavesBuscarFila_('IA',1,id),a=f?clavesFilaObjeto_('IA',f):{},cred=clavesTexto_(d.credencial||a.credencial);clavesUpsert_('IA',1,id,[id,clavesTexto_(d.nombre||a.nombre||id),clavesTexto_(d.tipo||a.tipo||'openai-compatible'),clavesTexto_(d.endpoint||a.endpoint),clavesTexto_(d.modelo||d.model||a.modelo),cred,clavesTexto_(d.estado||(d.activo===true?'ACTIVO':d.activo===false?'INACTIVO':a.estado||'INACTIVO')).toUpperCase(),Number(d.prioridad||a.prioridad||999),Number(d.timeoutMs||a.timeoutMs||45000),Number(d.maxTokens||a.maxTokens||3000),Number(d.temperatura===undefined?a.temperatura||0.3:d.temperatura),clavesTexto_(d.descripcion||a.descripcion),a.ultimaPruebaOk||false,a.ultimaPruebaEn||'',Number(a.ultimaLatenciaMs||0),a.ultimoError||'',new Date().toISOString()]);return{ok:true,proveedor:clavesListarIA_(true).proveedores.filter(function(x){return x.id===id;})[0]};}
