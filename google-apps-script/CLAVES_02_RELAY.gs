function clavesProveedor_(id){id=clavesId_(id);var f=clavesBuscarFila_('IA',1,id);if(!f)throw new Error('No existe el proveedor '+id+'.');var o=clavesFilaObjeto_('IA',f);if(!clavesActivo_(o.estado))throw new Error('El proveedor '+id+' está inactivo.');if(!clavesTexto_(o.credencial))throw new Error('El proveedor '+id+' no tiene credencial.');return o;}
