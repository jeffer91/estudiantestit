# Copia este archivo como .dev.vars en la raíz del proyecto.
# No subas .dev.vars a GitHub.

# URL /exec de la implementación del Apps Script de la hoja Claves.
CLAVES_APPS_SCRIPT_URL=https://script.google.com/macros/s/PEGA_AQUI_ID_CLAVES/exec

# Valor ACCESO_PROXY generado por prepararClavesCentral().
CLAVES_ACCESS_TOKEN=PEGA_AQUI_ACCESO_PROXY

# Opcional.
CLAVES_TIMEOUT_MS=30000
